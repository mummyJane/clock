[Unit]
Description=Clock web and bedside API server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=clock
Group=clock
WorkingDirectory=/opt/clock/project/web
EnvironmentFile=/etc/clock/clock.env
ExecStart=/usr/bin/python3 /opt/clock/project/web/server.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
